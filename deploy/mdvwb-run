#!/bin/sh
set -eu

CONFIG_FILE=${MDVWB_CONFIG_FILE:-/etc/default/mdvwb}
BINARY=${MDVWB_BINARY:-/usr/local/bin/MDVWB}

if [ ! -r "$CONFIG_FILE" ]; then
    echo "MDVWB configuration is not readable: $CONFIG_FILE" >&2
    exit 2
fi

# The configuration file is maintained by root and contains only shell-style
# variable assignments from deploy/mdvwb.env.
# shellcheck disable=SC1090
. "$CONFIG_FILE"

: "${MDVWB_ADDRESSES:?Set MDVWB_ADDRESSES in $CONFIG_FILE}"
: "${MDVWB_PORT:?Set MDVWB_PORT in $CONFIG_FILE}"
: "${MDVWB_BUS:?Set MDVWB_BUS in $CONFIG_FILE}"

MDVWB_MASTER_ID=${MDVWB_MASTER_ID:-0}
MDVWB_PERIOD_MS=${MDVWB_PERIOD_MS:-150}
MDVWB_RESPONSE_TIMEOUT_MS=${MDVWB_RESPONSE_TIMEOUT_MS:-130}
MDVWB_MQTT_HOST=${MDVWB_MQTT_HOST:-127.0.0.1}
MDVWB_MQTT_PORT=${MDVWB_MQTT_PORT:-1883}
MDVWB_MQTT_KEEPALIVE=${MDVWB_MQTT_KEEPALIVE:-60}
MDVWB_MQTT_RECONNECT=${MDVWB_MQTT_RECONNECT:-1}
MDVWB_MQTT_RECONNECT_MAX=${MDVWB_MQTT_RECONNECT_MAX:-10}
MDVWB_PUBLISH_POLL_ADDRESS=${MDVWB_PUBLISH_POLL_ADDRESS:-0}

if [ ! -x "$BINARY" ]; then
    echo "MDVWB executable is missing or not executable: $BINARY" >&2
    exit 3
fi

set -- "$BINARY" \
    --addresses "$MDVWB_ADDRESSES" \
    --port "$MDVWB_PORT" \
    --bus "$MDVWB_BUS" \
    --master-id "$MDVWB_MASTER_ID" \
    --period-ms "$MDVWB_PERIOD_MS" \
    --response-timeout-ms "$MDVWB_RESPONSE_TIMEOUT_MS" \
    --mqtt-host "$MDVWB_MQTT_HOST" \
    --mqtt-port "$MDVWB_MQTT_PORT" \
    --mqtt-keepalive "$MDVWB_MQTT_KEEPALIVE" \
    --mqtt-reconnect "$MDVWB_MQTT_RECONNECT" \
    --mqtt-reconnect-max "$MDVWB_MQTT_RECONNECT_MAX"

if [ -n "${MDVWB_MQTT_USER:-}" ]; then
    set -- "$@" --mqtt-user "$MDVWB_MQTT_USER"
    if [ -n "${MDVWB_MQTT_PASSWORD:-}" ]; then
        set -- "$@" --mqtt-password "$MDVWB_MQTT_PASSWORD"
    fi
fi

if [ "$MDVWB_PUBLISH_POLL_ADDRESS" = "1" ]; then
    set -- "$@" --publish-poll-address
fi

exec "$@"

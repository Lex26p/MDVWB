[Unit]
Description=MDV individual fan-coil MQTT driver, bus %i
Wants=network-online.target mosquitto.service wb-rules.service
After=network-online.target mosquitto.service wb-rules.service

[Service]
Type=simple
Environment=MDVWB_CONFIG_FILE=/etc/default/mdvwb-%i
ExecStart=/usr/local/lib/mdvwb/mdvwb-run
Restart=on-failure
RestartSec=5
User=root
Group=root
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target

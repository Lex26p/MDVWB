# MDVWB per-bus configuration template.
# Installed instances use /etc/default/mdvwb-<bus>.
MDVWB_ADDRESSES="1"
MDVWB_PORT="/dev/ttyRS485-1"
MDVWB_BUS="1"
MDVWB_MASTER_ID="0"

# One common start-to-start period for every C0/C3/CC/CD transaction.
MDVWB_PERIOD_MS="150"
MDVWB_RESPONSE_TIMEOUT_MS="130"

MDVWB_MQTT_HOST="127.0.0.1"
MDVWB_MQTT_PORT="1883"
MDVWB_MQTT_USER=""
MDVWB_MQTT_PASSWORD=""
MDVWB_MQTT_KEEPALIVE="60"
MDVWB_MQTT_RECONNECT="1"
MDVWB_MQTT_RECONNECT_MAX="10"

# 1 publishes GanGetID every transaction; keep 0 during normal operation.
MDVWB_PUBLISH_POLL_ADDRESS="0"
